{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flux-installer",
  "version": "0.1.0",
  "identifier": "dev.fluxos.installer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Flux App Installer",
        "width": 1000,
        "height": 680,
        "minWidth": 800,
        "minHeight": 520,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png"]
  }
}
