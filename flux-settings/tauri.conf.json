{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flux-settings",
  "version": "0.1.0",
  "identifier": "dev.fluxos.settings",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Flux Settings",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}
