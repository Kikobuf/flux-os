#!/bin/bash

# flux:summary=Install the Tailscale mesh VPN service and a web app for the Tailscale Admin Console.
# flux:requires-sudo=true

echo -e "\nInstalling Tailscale..."
flux-pkg-add tailscale

echo -e "\nStarting Tailscale..."
sudo systemctl enable --now tailscaled.service
sudo tailscale up --accept-routes

flux-webapp-install "Tailscale" "https://login.tailscale.com/admin/machines" https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/tailscale-light.png
