#!/bin/bash
# flux-install-browser — install a browser by ID from onboarding
set -euo pipefail
case "${1:-}" in
  chrome)      yay -S --noconfirm google-chrome ;;
  firefox)     sudo pacman -S --noconfirm --needed firefox ;;
  brave)       yay -S --noconfirm brave-bin ;;
  chromium)    sudo pacman -S --noconfirm --needed chromium ;;
  opera)       yay -S --noconfirm opera ;;
  vivaldi)     yay -S --noconfirm vivaldi vivaldi-ffmpeg-codecs ;;
  zen)         yay -S --noconfirm zen-browser-bin ;;
  librewolf)   yay -S --noconfirm librewolf-bin ;;
  *)           echo "Unknown browser: ${1:-}" >&2; exit 1 ;;
esac
echo "✓ Installed: ${1}"
