#!/bin/bash

# flux:summary=Set or toggle shape of Hyprland window corners
# flux:args=[toggle|sharp|round]
# flux:examples=flux style corners hyprland toggle | flux style corners hyprland round | flux style corners hyprland sharp

case "${1:-toggle}" in
  round) set -- on ;;
  sharp) set -- off ;;
  toggle) ;;
  *)
    echo "Usage: flux-style-corners-hyprland [toggle|sharp|round]"
    exit 1
    ;;
esac

flux-hyprland-toggle rounded-corners "$1"
