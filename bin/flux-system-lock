#!/bin/bash

# flux:summary=Lock the computer and turn off the display
# flux:group=system
# flux:name=lock
# flux:examples=flux system lock

if ! pidof hyprlock >/dev/null; then
  (
    hyprlock
    flux-system-wake
  ) &
fi

# Set keyboard layout to default (first layout)
hyprctl switchxkblayout all 0 > /dev/null 2>&1

# Ensure 1password is locked
if pgrep -x "1password" >/dev/null; then
  1password --lock &
fi

# Avoid running screensaver when locked
pkill -f org.flux.screensaver

if [[ ${FLUX_LOCK_ONLY:-false} != "true" ]]; then
  (
    sleep 3
    pidof hyprlock >/dev/null || exit 0
    flux-brightness-keyboard off
    flux-brightness-display off
  ) &
fi
