#!/bin/bash

# flux:summary=Set the Flux channel, which dictates what git branch and package repository is used.
# flux:args=<stable|rc|edge|dev>
# flux:requires-sudo=true

if (($# == 0)); then
  echo "Usage: flux-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") flux-branch-set "master" && flux-refresh-pacman "stable" ;;
"rc") flux-branch-set "rc" && flux-refresh-pacman "rc" ;;
"edge") flux-branch-set "master" && flux-refresh-pacman "edge" ;;
"dev") flux-branch-set "dev" && flux-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

flux-update -y
