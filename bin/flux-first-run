#!/bin/bash

# flux:summary=Finish the installation of Flux with items that can only be done after logging in.
# flux:requires-sudo=true

set -e

FIRST_RUN_MODE=~/.local/state/flux/first-run.mode

if [[ -f $FIRST_RUN_MODE ]]; then
  rm -f "$FIRST_RUN_MODE"

  bash "$FLUX_PATH/install/first-run/battery-monitor.sh"
  bash "$FLUX_PATH/install/first-run/recover-internal-monitor.sh"
  bash "$FLUX_PATH/install/first-run/cleanup-reboot-sudoers.sh"
  bash "$FLUX_PATH/install/first-run/firewall.sh"
  bash "$FLUX_PATH/install/first-run/dns-resolver.sh"
  bash "$FLUX_PATH/install/first-run/gnome-theme.sh"
  bash "$FLUX_PATH/install/first-run/gdk-scale.sh"
  bash "$FLUX_PATH/install/first-run/swayosd.sh"
  bash "$FLUX_PATH/install/first-run/gtk-primary-paste.sh"
  bash "$FLUX_PATH/install/first-run/elephant.sh"
  flux-hook-install post-update "$FLUX_PATH/install/first-run/install-voxtype.hook"
  sudo rm -f /etc/sudoers.d/first-run

  bash "$FLUX_PATH/install/first-run/welcome.sh"
  bash "$FLUX_PATH/install/first-run/wifi.sh"
fi

# Flux onboarding wizard (runs on first boot if not already complete)
flux-first-run-onboarding
