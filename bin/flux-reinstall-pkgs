#!/bin/bash

# flux:summary=Reinstall all default Flux packages from the stable channel
# flux:requires-sudo=true

set -e

# Reinstall all default Flux packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
flux-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$FLUX_PATH/install/flux-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
