#!/bin/bash

# flux:summary=Run a named hook from ~/.config/flux/hooks/<name> and ~/.config/flux/hooks/<name>.d/.
# flux:args=[name] [args...]

set -e

if (( $# < 1 )); then
  echo "Usage: flux-hook [name] [args...]"
  exit 1
fi

HOOK=$1
HOOK_PATH="$HOME/.config/flux/hooks/$1"
HOOK_DIR="$HOOK_PATH.d"
shift

if [[ -f $HOOK_PATH ]]; then
  bash "$HOOK_PATH" "$@" || echo "Hook failed: $HOOK_PATH"
fi

if [[ -d $HOOK_DIR ]]; then
  for hook in "$HOOK_DIR"/*; do
    [[ -f $hook ]] || continue
    [[ $hook == *.sample ]] && continue
    bash "$hook" "$@" || echo "Hook failed: $hook"
  done
fi
