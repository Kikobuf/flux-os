#!/bin/bash

# flux:summary=Set the Plymouth boot theme from an Flux theme
# flux:args=<theme-name>
# flux:requires-sudo=true

# Resolve a theme by name and apply its unlock.png + colors.toml as the
# Plymouth boot screen via flux-plymouth-set.

if [[ $# -ne 1 ]]; then
  echo "Usage: flux-plymouth-set-by-theme <theme-name>" >&2
  exit 1
fi

theme=$1

if [[ -d ~/.config/flux/themes/$theme ]]; then
  theme_dir=~/.config/flux/themes/$theme
else
  theme_dir="$FLUX_PATH/themes/$theme"
fi

bg=$(awk -F'"' '/^background/{print $2}' "$theme_dir/colors.toml")
text=$(awk -F'"' '/^foreground/{print $2}' "$theme_dir/colors.toml")

exec flux-plymouth-set "$bg" "$text" "$theme_dir/unlock.png"
