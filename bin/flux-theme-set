#!/bin/bash

# flux:summary=Apply an Flux theme
# flux:args=<theme-name>
# flux:examples=flux theme list | flux theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: flux-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/flux/current/theme"
NEXT_THEME_PATH="$HOME/.config/flux/current/next-theme"
USER_THEMES_PATH="$HOME/.config/flux/themes"
FLUX_THEMES_PATH="$FLUX_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $FLUX_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$FLUX_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  flux-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
flux-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/flux/current/theme.name"

# Change background with theme
if [[ $FLUX_THEME_SKIP_BACKGROUND != "1" ]]; then
  flux-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  flux-restart-waybar
fi
flux-restart-swayosd
flux-restart-terminal
flux-restart-hyprctl
flux-restart-btop
flux-restart-opencode
flux-restart-mako
flux-restart-helix

# Change app-specific themes
flux-theme-set-foot
flux-theme-set-gnome
flux-theme-set-browser
flux-theme-set-vscode
flux-theme-set-obsidian
flux-theme-set-keyboard

# Call hook on theme set
flux-hook theme-set "$THEME_NAME" >/dev/null

# Warm the background selector cache after the theme is applied, off the critical path.
flux-theme-bg-cache >/dev/null 2>&1 &
