#!/bin/bash

# flux:summary=Launch or focus on a given web app identified by the window-pattern.
# flux:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: flux-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="flux-launch-webapp $@"

exec flux-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
