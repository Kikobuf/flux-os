#!/bin/bash

# flux:summary=Reinstall Flux packages and reset default configs
# flux:requires-sudo=true

set -e

# Attempt to reinstall all default Flux packages and reset all the default configs.

echo -e "This will reinstall all the default Flux packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  flux-reinstall-git
  flux-reinstall-pkgs
  flux-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && flux-system-reboot
fi
