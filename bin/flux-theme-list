#!/bin/bash

# flux:summary=List available themes
# flux:examples=flux theme list | flux theme set "Tokyo Night"

{
  find ~/.config/flux/themes/ -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -printf '%f\n'
  find "$FLUX_PATH/themes/" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
} | sort -u | while read -r name; do
  echo "$name" | sed -E 's/(^|-)([a-z])/\1\u\2/g; s/-/ /g'
done
